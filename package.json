{
  "name": "@jvstack/helpers",
  "description": "Collection of helpers i use in all my projects",
  "author": "João Vitor Ceolin Prudente",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvstack-dev/jvstack_helpers.git"
  },
  "homepage": "https://github.com/jvstack-dev/jvstack_helpers",
  "bugs": {
    "url": "https://github.com/jvstack-dev/jvstack_helpers/issues"
  },
  "keywords": [
    "helpers",
    "utils",
    "jvstack"
  ],
  "version": "0.2.5",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6"
  },
  "engines": {
    "node": ">=20"
  }
}
